<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <Platforms>AnyCPU</Platforms>
        <NoWarn>$(NoWarn);1591</NoWarn>
    </PropertyGroup>

    <PropertyGroup>
        <Description>Automatically updates the Soenneker.SimpleIcons.Icons package, daily</Description>
        <Version Condition="'$(BUILD_VERSION)' == ''">4.0.0</Version>
        <Version Condition="'$(BUILD_VERSION)' != ''">$(BUILD_VERSION)</Version>
        <AssemblyName>Soenneker.SimpleIcons.Runners.Icons</AssemblyName>
        <Copyright>Copyright © 2026 Jake Soenneker</Copyright>
        <Authors>Jake Soenneker</Authors>
        <Company>https://soenneker.com</Company>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <IsPackable>false</IsPackable>
        <LangVersion>latest</LangVersion>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Soenneker.Extensions.LoggerConfiguration" Version="4.0.1271" />
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
        <PackageReference Include="Soenneker.Hashing.XxHash" Version="4.0.57" />
        <PackageReference Include="Soenneker.Git.Util" Version="4.0.3563" />
        <PackageReference Include="Soenneker.Utils.Dotnet" Version="4.0.2414" />
        <PackageReference Include="Soenneker.Utils.Dotnet.NuGet" Version="4.0.1997" />
        <PackageReference Include="Soenneker.Utils.Directory" Version="4.0.868" />
        <PackageReference Include="Soenneker.Utils.File" Version="4.0.2175" />
        <PackageReference Include="Soenneker.Utils.PooledStringBuilders" Version="4.0.22" />
    </ItemGroup>
</Project>
